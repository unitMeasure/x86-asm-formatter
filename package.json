{
  "name": "x86-asm-formatter",
  "displayName": "x86 Intel ASM Formatter",
  "description": "Formats x86 Intel assembly code, normalizes tabs, and aligns comments.",
  "version": "1.0.8",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Formatters"
  ],
  "publisher": "unitMeasure",
  "activationEvents": [
    "onLanguage:assembly",
    "onLanguage:asm",
    "onLanguage:asm-intel-x86-generic",
    "onLanguage:x86",
    "onLanguage:x86_64",
    "onLanguage:nasm",
    "onLanguage:masm",
    "onLanguage:fasm"
  ],
  "keywords": [
    "assembly",
    "x86",
    "formatter",
    "asm",
    "intel",
    "assembly-formatting",
    "code-formatter",
    "assembly-code",
    "x86-assembly"
  ],
  "main": "./extension.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/unitMeasure/x86-asm-formatter.git"
  },
  "sponsor": {
    "url": "https://github.com/sponsors/avipars"
  },
  "contributes": {
    "languages": [
      {
        "id": "assembly",
        "aliases": [
          "Assembly",
          "asm"
        ],
        "extensions": [
          ".asm",
          ".s",
          ".inc"
        ]
      }
    ]
  },
  "pricing": "Free",
  "icon": "images/icon_small.png",
  "license": "Apache-2.0"
}